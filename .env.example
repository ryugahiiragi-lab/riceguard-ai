# Salin isi file ini sebagai acuan saat mengisi "Environment Variables" di dashboard Render.
# JANGAN commit file .env asli (berisi kredensial sungguhan) ke GitHub — sudah otomatis
# diabaikan lewat .gitignore.

# Kunci rahasia Flask untuk session/flash. Ganti dengan string acak, jangan pakai contoh ini.
SECRET_KEY=ganti-dengan-string-acak-yang-panjang-dan-rahasia

# Connection string MySQL dari Aiven (lihat halaman "Overview" service Aiven kamu).
# Kalau Aiven mewajibkan SSL, tambahkan ?ssl_ca=aiven-ca.pem di akhir (lihat panduan deploy).
DATABASE_URL=mysql+pymysql://USERNAME:PASSWORD@HOST:PORT/DBNAME

# Biarkan False di production. Hanya isi True kalau debug lokal.
FLASK_DEBUG=False
